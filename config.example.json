{
  "settings": {
    "skip_if_done_today": true,
    "timeout_hours": 8
  },
  "nodes": [
    { "id": "root",        "type": "confirm", "prompt": "Train today?",               "yes": "warmup",      "no": "exit" },
    { "id": "warmup",      "type": "confirm", "prompt": "Warmup? (keyboard trainer)",  "yes": "open-typing", "no": "main" },
    { "id": "open-typing", "type": "open",    "url": "https://monkeytype.com", "no_state": true },

    { "id": "main", "type": "select", "prompt": "What do you wanna learn?",
      "options": [
        { "label": "Programming language", "next": "lang"  },
        { "label": "Tool",                 "next": "tool"  },
        { "label": "Skill",                "next": "skill" }
      ]
    },

    { "id": "lang", "type": "select", "prompt": "Pick a language",
      "options": [
        { "label": "Go",   "next": "open-go"   },
        { "label": "Rust", "next": "open-rust" },
        { "label": "Jai",  "next": "open-jai"  }
      ]
    },
    { "id": "open-go",   "type": "cmd", "cmd": "alacritty --working-directory ~/Projects/golings -e golings watch & alacritty --working-directory ~/Projects/golings", "async": true },
    { "id": "open-rust", "type": "cmd", "cmd": "alacritty --working-directory ~/Projects/rustlings -e rustlings watch", "async": true },
    { "id": "open-jai",  "type": "cmd", "cmd": "alacritty --working-directory ~/Projects/try-jai", "async": true },

    { "id": "tool", "type": "select", "prompt": "Pick a tool",
      "options": [
        { "label": "Vim",   "next": "cmd-vim"   },
        { "label": "Emacs", "next": "cmd-emacs" },
        { "label": "Git",   "next": "cmd-git"   }
      ]
    },
    { "id": "cmd-vim",   "type": "cmd", "cmd": "alacritty -e vimtutor", "async": true },
    { "id": "cmd-emacs", "type": "cmd", "cmd": "alacritty -e emacs --eval '(help-with-tutorial)'", "async": true },
    { "id": "cmd-git",   "type": "cmd", "cmd": "steam steam://rungameid/1490570", "async": true },

    { "id": "skill", "type": "select", "prompt": "Pick a skill",
      "options": [
        { "label": "Morse code", "next": "open-morse" }
      ]
    },
    { "id": "open-morse", "type": "open", "url": "https://lcwo.net" },

    { "id": "exit", "type": "exit" }
  ]
}
